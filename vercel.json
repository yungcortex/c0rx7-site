{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "regions": ["fra1"],
  "buildCommand": "cd game && npm install && npm run build && rm -rf ../play && mv dist ../play",
  "outputDirectory": ".",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./game ./vercel.json ./index.html ./api ./supabase-schema.sql || exit 1",
  "rewrites": [
    { "source": "/play",          "destination": "/play/index.html" },
    { "source": "/play/",         "destination": "/play/index.html" },
    { "source": "/binance/:path*",      "destination": "https://fapi.binance.com/:path*" },
    { "source": "/binance-spot/:path*", "destination": "https://api.binance.com/:path*" },
    { "source": "/gate/:path*",    "destination": "https://api.gateio.ws/:path*" },
    { "source": "/gatefx/:path*",  "destination": "https://fx-api.gateio.ws/:path*" },
    { "source": "/kucoin/:path*",  "destination": "https://api-futures.kucoin.com/:path*" },
    { "source": "/cbintx/:path*",  "destination": "https://api.international.coinbase.com/:path*" },
    { "source": "/econcal/:path*", "destination": "https://nfs.faireconomy.media/:path*" },
    { "source": "/farside/:path*", "destination": "https://farside.co.uk/:path*" },
    { "source": "/llama/:path*",   "destination": "https://api.llama.fi/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/binance/fapi/v1/ticker/24hr",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=5, stale-while-revalidate=15" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=5, stale-while-revalidate=15" }
      ]
    },
    {
      "source": "/binance/fapi/v1/premiumIndex",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=5, stale-while-revalidate=15" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=5, stale-while-revalidate=15" }
      ]
    },
    {
      "source": "/binance-spot/api/v3/ticker/price",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=5, stale-while-revalidate=15" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=5, stale-while-revalidate=15" }
      ]
    },
    {
      "source": "/binance/fapi/v1/fundingRate",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=30, stale-while-revalidate=120" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=120" }
      ]
    },
    {
      "source": "/binance/futures/data/(.*)",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=30, stale-while-revalidate=120" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=120" }
      ]
    },
    {
      "source": "/binance/fapi/v1/klines",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=15, stale-while-revalidate=60" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=15, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/binance/fapi/v1/openInterest",
      "headers": [
        { "key": "CDN-Cache-Control",    "value": "public, s-maxage=10, stale-while-revalidate=30" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=10, stale-while-revalidate=30" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
